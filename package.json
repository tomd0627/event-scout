{
  "name": "event-scout",
  "version": "1.0.0",
  "description": "AI-powered local event discovery — curated by Claude, not an algorithm.",
  "private": true,
  "scripts": {
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:js": "eslint \"js/**/*.js\"",
    "lint:html": "html-validate index.html",
    "lint": "npm run lint:css && npm run lint:js && npm run lint:html",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "validate": "npm run lint && npm run format:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "html-validate": "^11.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1"
  }
}
